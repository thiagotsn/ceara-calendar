# Copy to .env and fill in real values. .env is gitignored.
#
# Each calendar is independently credentialed: its own calendar ID, its own
# service account JSON, and an optional JWT subject for domain-wide delegation.
# Adding a new calendar means adding a new block here, a registry entry in
# shared/calendars.ts, and matching GitHub secrets.

# --- CEARA ---
CEARA_CALENDAR_ID=calendarioceara@gmail.com
# Single-line compact JSON of the service account key, wrapped in single quotes.
CEARA_GOOGLE_KEYS_JSON='{"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@...iam.gserviceaccount.com"}'
# JWT subject for domain-wide delegation. Leave blank if the calendar is shared
# directly with the service account email.
CEARA_GOOGLE_SERVICE_ACCOUNT=

# --- World Cup 2026 ---
WORLD_CUP_2026_CALENDAR_ID=calendariocopa@gmail.com
WORLD_CUP_2026_GOOGLE_KEYS_JSON='{"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@...iam.gserviceaccount.com"}'
WORLD_CUP_2026_GOOGLE_SERVICE_ACCOUNT=

# --- API-Football (shared across calendars) ---
API_FOOTBALL_ENDPOINT=v3.football.api-sports.io
API_FOOTBALL_KEY=your-rapidapi-key

# --- SportsAPI Pro (shared across calendars; currently used by Ceará) ---
SPORTS_API_PRO_KEY=your-sportsapipro-key
